# MongoDB root credentials (used by the mongo container on first init)
MONGO_INITDB_ROOT_USERNAME=taskflow
MONGO_INITDB_ROOT_PASSWORD=change_this_to_a_strong_password

# Backend connection string — must match the credentials above
MONGO_URI=mongodb://taskflow:change_this_to_a_strong_password@mongo:27017/taskflow?authSource=admin

JWT_SECRET=change_this_to_a_long_random_string
# 32-byte hex key for encrypting stored GitHub tokens. Generate: openssl rand -hex 32
ENCRYPTION_KEY=change_this_to_a_64_char_hex_string
PORT=5000
NODE_ENV=production

# Set to true when served over HTTPS so the auth cookie gets the Secure flag.
# Leave false/unset for plain-HTTP (localhost) testing, or the cookie is dropped.
COOKIE_SECURE=true

# Optional: allowed CORS origin. Leave unset for same-origin (served via nginx).
# CORS_ORIGIN=https://taskflow.example.com
